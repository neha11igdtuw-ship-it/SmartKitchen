PORT=3000
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/smartkitchen
# Atlas (replace USER, PASS, CLUSTER, and DB name):
# MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/smartkitchen

# JWT for household auth (/api/auth/login, /api/auth/register)
# User passwords are stored as PBKDF2 hashes in MongoDB only; use HTTPS in production.
JWT_SECRET=change-this-to-a-long-random-string
# Default session length; “Keep me signed in” uses JWT_EXPIRES_IN_REMEMBER (default 90d)
# JWT_EXPIRES_IN=30d
# JWT_EXPIRES_IN_REMEMBER=90d

# Seeded demo users (npm run seed) — optional override for demo member password
# DEMO_MEMBER_PASSWORD=demo12345

# Google AI (Gemini) — AI Insights (GET /api/insights/gemini/status, POST /api/insights/gemini)
# and E‑commerce “Import from screenshot” (POST /api/commerce/parse-order-screenshot; vision)
# Create a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# Optional: primary model (server falls back through several if this fails)
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=25000
# Open the app from the same host/port as this server (e.g. http://localhost:3000/ai-insights.html) so /api/insights works.

# Demo data: npm run seed  |  Reset deals/messages/recipes: SEED_FORCE=1 npm run seed
